# AI Training Assistant Environment Configuration

# Ollama Settings
OLLAMA_API_URL=http://localhost:11434/api/generate
MODEL_NAME=llama3.2

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector Store
VECTORSTORE_PATH=vectorstore/index.faiss

# Database
DATABASE_PATH=backend/progress.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# RAG Settings
RAG_TOP_K=3
RAG_TEMPERATURE=0.3
